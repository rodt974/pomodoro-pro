# ============================================================
# Pomodoro Pro — environment template
# Copy this file to .env.local and fill in real values.
# ============================================================

# --- Supabase ---------------------------------------------------------------
# Project URL from https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=

# Public anon key (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — SERVER ONLY. Used by the Stripe webhook to upsert
# subscriptions, bypassing RLS. Never import from a client component.
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe (test mode) -----------------------------------------------------
# https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_

# Generated when you run `stripe listen --forward-to localhost:3000/api/stripe/webhook`
# In production, set this from the dashboard webhook endpoint.
STRIPE_WEBHOOK_SECRET=whsec_

# Price IDs from https://dashboard.stripe.com/test/products
# Create two recurring prices: Pro $19/mo, Team $49/mo
NEXT_PUBLIC_STRIPE_PRICE_PRO=price_
NEXT_PUBLIC_STRIPE_PRICE_TEAM=price_

# --- OpenAI ----------------------------------------------------------------
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-

# --- App -------------------------------------------------------------------
# Used for Stripe success/cancel redirect URLs and the Supabase auth callback.
# In production set this to your Vercel deployment URL (no trailing slash).
NEXT_PUBLIC_APP_URL=http://localhost:3000
